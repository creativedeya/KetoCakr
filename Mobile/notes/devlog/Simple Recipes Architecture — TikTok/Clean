## ✅ Database Cleanup (SQL Migration)

### Create and Run this SQL in Supabase

```sql
-- ===================================================================
-- CLEANUP: Remove old simple recipes infrastructure
-- ===================================================================

-- Step 1: Drop the all_recipes VIEW (depends on standalone_recipes)
DROP VIEW IF EXISTS all_recipes CASCADE;

-- Step 2: Drop the admin_simple_recipes / standalone_recipes table
DROP TABLE IF EXISTS standalone_recipes CASCADE;
DROP TABLE IF EXISTS admin_simple_recipes CASCADE;

-- Step 3: Verify cleanup
-- Run this to confirm tables are gone:
SELECT tablename 
FROM pg_tables 
WHERE schemaname='public' 
AND (tablename LIKE '%simple%' OR tablename LIKE '%standalone%');
-- Should return: (0 rows)

-- ===================================================================
-- NEW INFRASTRUCTURE: Simple recipes integrated into base_recipes
-- ===================================================================

-- Step 4: Add columns to base_recipes for simple recipe support
ALTER TABLE base_recipes
ADD COLUMN IF NOT EXISTS is_simple_recipe BOOLEAN DEFAULT FALSE,
ADD COLUMN IF NOT EXISTS source_type VARCHAR(50) DEFAULT 'puzzle_component',
ADD COLUMN IF NOT EXISTS source_url TEXT;

-- Add comment for clarity
COMMENT ON COLUMN base_recipes.is_simple_recipe IS 'TRUE for TikTok/Instagram/user-saved recipes, FALSE for puzzle components';
COMMENT ON COLUMN base_recipes.source_type IS 'puzzle_component | tiktok | instagram | website | manual | user_saved';
COMMENT ON COLUMN base_recipes.source_url IS 'URL to original source (TikTok link, blog post, etc)';

-- Step 5: Verify new columns exist
SELECT column_name, data_type 
FROM information_schema.columns 
WHERE table_name='base_recipes' 
AND column_name IN ('is_simple_recipe', 'source_type', 'source_url')
ORDER BY ordinal_position;
-- Should return: 3 rows with new columns

-- ===================================================================
-- CREATE: user_saved_recipes table for Phase 4
-- ===================================================================

CREATE TABLE IF NOT EXISTS user_saved_recipes (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  
  -- Basic info
  name TEXT NOT NULL,
  name_bg TEXT,
  name_en TEXT,
  description TEXT,
  description_bg TEXT,
  description_en TEXT,
  
  -- Media
  image_url TEXT,
  
  -- Source (where user found the recipe)
  source_type VARCHAR(50) NOT NULL,  -- 'tiktok', 'instagram', 'pinterest', 'blog', 'manual', 'youtube'
  source_url TEXT,                   -- Link to original source
  
  -- Recipe data (will use recipe_ingredients & recipe_instruction_steps with FK)
  -- See separate migration for those tables
  
  -- Nutrition (calculated from ingredients)
  total_calories DECIMAL,
  total_protein DECIMAL,
  total_fat DECIMAL,
  total_carbs DECIMAL,
  total_net_carbs DECIMAL,
  total_fiber DECIMAL,
  total_weight_grams INTEGER,
  servings INTEGER DEFAULT 1,
  
  -- Metadata
  is_public BOOLEAN DEFAULT FALSE,   -- Can user share with others (future feature)
  is_favorite BOOLEAN DEFAULT FALSE,
  tags TEXT[],
  
  -- Timestamps
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  
  CONSTRAINT user_saved_recipes_unique_per_user UNIQUE(user_id, name)
);

-- Add indexes for performance
CREATE INDEX IF NOT EXISTS idx_user_saved_recipes_user_id 
ON user_saved_recipes(user_id);

CREATE INDEX IF NOT EXISTS idx_user_saved_recipes_created 
ON user_saved_recipes(user_id, created_at DESC);

CREATE INDEX IF NOT EXISTS idx_user_saved_recipes_source_type 
ON user_saved_recipes(source_type);

-- ===================================================================
-- CREATE: recipe_ingredients for user_saved_recipes
-- ===================================================================

CREATE TABLE IF NOT EXISTS user_saved_recipe_ingredients (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_saved_recipe_id UUID NOT NULL REFERENCES user_saved_recipes(id) ON DELETE CASCADE,
  ingredient_database_id UUID REFERENCES ingredients_database(id) ON DELETE SET NULL,
  
  -- Manual entry (if ingredient not in database)
  ingredient_name TEXT,
  
  -- Quantity
  quantity DECIMAL NOT NULL,
  unit VARCHAR(20),  -- 'g', 'ml', 'tsp', 'tbsp', 'cup', 'oz', 'piece', etc
  
  -- Ordering
  order_index INTEGER,
  
  -- Timestamps
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  
  CONSTRAINT user_saved_ingredients_valid_source CHECK (
    (ingredient_database_id IS NOT NULL) OR (ingredient_name IS NOT NULL)
  )
);

CREATE INDEX IF NOT EXISTS idx_user_saved_recipe_ingredients_recipe_id 
ON user_saved_recipe_ingredients(user_saved_recipe_id);

-- ===================================================================
-- CREATE: recipe_instruction_steps for user_saved_recipes
-- ===================================================================

CREATE TABLE IF NOT EXISTS user_saved_recipe_instruction_steps (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_saved_recipe_id UUID NOT NULL REFERENCES user_saved_recipes(id) ON DELETE CASCADE,
  
  -- Step info
  step_number INTEGER NOT NULL,
  step_description TEXT NOT NULL,
  step_description_bg TEXT,
  step_description_en TEXT,
  
  -- Media
  step_image_url TEXT,  -- Can be auto-generated or user-uploaded
  
  -- Timing
  step_duration_minutes INTEGER DEFAULT 5,
  
  -- Equipment needed for this step
  equipment_needed INTEGER[],  -- References equipment.id
  
  -- Timestamps
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  
  CONSTRAINT user_saved_steps_unique_step_number UNIQUE(user_saved_recipe_id, step_number)
);

CREATE INDEX IF NOT EXISTS idx_user_saved_recipe_steps_recipe_id 
ON user_saved_recipe_instruction_steps(user_saved_recipe_id);

-- ===================================================================
-- VERIFICATION: Run these queries to confirm everything is set up
-- ===================================================================

-- Check base_recipes has new columns:
SELECT COUNT(*) as base_recipes_with_new_columns
FROM information_schema.columns 
WHERE table_name='base_recipes' 
AND column_name IN ('is_simple_recipe', 'source_type', 'source_url');
-- Should return: 3

-- Check user_saved_recipes table exists:
SELECT COUNT(*) as user_saved_recipes_exists
FROM information_schema.tables
WHERE table_name='user_saved_recipes';
-- Should return: 1

-- Check no simple_recipes / standalone_recipes tables remain:
SELECT COUNT(*) as unwanted_tables
FROM information_schema.tables
WHERE table_name LIKE '%simple%' OR table_name LIKE '%standalone%';
-- Should return: 0
```

