### C. Create SimpleRecipeCard Component

**File:** `Mobile/components/recipe/SimpleRecipeCard.tsx`

```typescript
import React from 'react';
import { View, Text, TouchableOpacity, Image, StyleSheet } from 'react-native';
import { Ionicons } from '@expo/vector-icons';
import { Colors } from '../../constants/Colors';
import { Typography, Spacing, BorderRadius, Shadows } from '../../constants/Theme';

interface SimpleRecipeCardProps {
  id: number;
  name: string;
  image_url?: string;
  calories?: number;
  servings?: number;
  source_type?: string;
  onPress: () => void;
}

export default function SimpleRecipeCard({
  id,
  name,
  image_url,
  calories,
  servings,
  source_type,
  onPress,
}: SimpleRecipeCardProps) {
  // Source type icons
  const sourceIcon = {
    tiktok: '▶',
    instagram: '📷',
    website: '🌐',
    user: '👤',
  }[source_type || 'website'] || '✨';

  return (
    <TouchableOpacity
      onPress={onPress}
      style={styles.card}
      activeOpacity={0.8}
    >
      {image_url ? (
        <Image
          source={{ uri: image_url }}
          style={styles.image}
        />
      ) : (
        <View style={[styles.image, styles.placeholder]}>
          <Ionicons name="image-outline" size={32} color={Colors.text.tertiary} />
        </View>
      )}

      {/* Source Badge */}
      {source_type && (
        <View style={styles.badge}>
          <Text style={styles.badgeText}>{sourceIcon}</Text>
        </View>
      )}

      {/* Overlay with info */}
      <View style={styles.overlay}>
        <Text style={styles.name} numberOfLines={2}>
          {name}
        </Text>

        {calories && (
          <View style={styles.infoRow}>
            <Ionicons
              name="flame"
              size={14}
              color={Colors.primary.main}
            />
            <Text style={styles.infoText}>
              {Math.round(calories)} cal
            </Text>
          </View>
        )}

        {servings && (
          <View style={styles.infoRow}>
            <Ionicons
              name="restaurant-outline"
              size={14}
              color={Colors.primary.main}
            />
            <Text style={styles.infoText}>
              {servings} serving{servings !== 1 ? 's' : ''}
